    "@swo/mp-api-model": "^5.2.524",
    "@swo/rql-client": "^5.0.13",
    "@swo/service": "^5.0.2",
    "axios": "^1.13.5",
    "esbuild-sass-plugin": "^3.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.27.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3"
  }
